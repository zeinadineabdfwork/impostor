# ─────────────────────────────────────────────
# ImpostorDraw — Variáveis de Ambiente
# Copie este ficheiro para .env e preencha os valores
# NUNCA faça commit do .env
# ─────────────────────────────────────────────

# ── Servidor ──────────────────────────────────
PORT=3000
NODE_ENV=production

# ── JWT ───────────────────────────────────────
JWT_SECRET=coloca_aqui_um_segredo_longo_e_aleatorio
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=coloca_aqui_outro_segredo_diferente

# ── Supabase ──────────────────────────────────
# ATENÇÃO: usar apenas a URL base do projeto, SEM /rest/v1/ no final
# Exemplo correto:   https://xxxx.supabase.co
# Exemplo ERRADO:    https://xxxx.supabase.co/rest/v1/
SUPABASE_URL=https://SEUPROJETO.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── PostgreSQL Directo (Pool) ─────────────────
# Usar a connection string do Supabase (Transaction Pooler porta 6543 ou Session Pooler porta 5432)
DATABASE_URL=postgresql://postgres.SEUPROJETO:SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres

# ── CORS ──────────────────────────────────────
# URL(s) do frontend separadas por vírgula
# No Render, usar a URL do teu serviço frontend (ex: https://impostor-frontend.onrender.com)
# Para desenvolvimento local: http://localhost:5500,http://localhost:3000
CORS_ORIGIN=https://SEU-FRONTEND.onrender.com

# ── Upload de Avatares ────────────────────────
MAX_AVATAR_SIZE_MB=2
# No Render, o filesystem é efémero — avatares perdem-se ao reiniciar
# Considera usar Supabase Storage em vez de disco local
AVATARS_UPLOAD_DIR=./public/assets/avatars/uploads

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# ── Jogo ──────────────────────────────────────
MAX_STROKE_LENGTH=200
MAX_ROUNDS=6
MIN_PLAYERS=3
MAX_PLAYERS=8
VOTE_TIMEOUT_SECONDS=25
TURN_TIMEOUT_SECONDS=30
DISCONNECT_TOLERANCE_SECONDS=25
